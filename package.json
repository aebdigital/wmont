{
  "name": "wmont-next-rebuild",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3007",
    "dev:clean": "rm -rf .next && next dev --hostname 127.0.0.1 --port 3007",
    "dev:3000": "next dev --hostname 127.0.0.1 --port 3000",
    "check": "tsc --noEmit",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3007",
    "lint": "next lint",
    "generate:content": "node scripts/generate-content.mjs"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
